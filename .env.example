# =============================================================
# .env.example — Variáveis de Ambiente - Hotspot Auth
# =============================================================
# COMO USAR:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores abaixo
#   3. NÃO faça commit do arquivo .env no Git!
#
# No Coolify: cole cada variável na aba "Environment Variables"
# =============================================================

# ── MikroTik RouterOS ─────────────────────────────────────
# IP do roteador (acessível pelo VPS via internet ou VPN)
MIKROTIK_HOST=SEU_IP_PUBLICO_OU_IP_MIKROTIK

# Usuário com permissão de API no MikroTik
MIKROTIK_USER=admin

# Senha do usuário (deixe vazio se não tiver senha)
MIKROTIK_PASSWORD=SUA_SENHA_AQUI

# Porta da API RouterOS (padrão: 8728)
MIKROTIK_PORT=8728

# ── Hotspot ───────────────────────────────────────────────
# Nome exato do perfil criado no script .rsc
HOTSPOT_PROFILE=perfil-padrao

# URL para onde redirecionar após login (fallback)
DEFAULT_REDIRECT=http://www.google.com

# ── Logs ──────────────────────────────────────────────────
# Caminho interno do container (não altere se usar volume)
LOG_FILE=/data/acessos.txt
